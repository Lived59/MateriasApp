@page "/agregar-profesor/{nombreMateria}"
@using Domain.Entities
@using Repository
@inject ProfesorRepository Repo
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="form-container">

    <NavLink href="@($"/profesores/{nombreMateria}")" class="btn-volver">
        ← Volver
    </NavLink>

    <h1>Agregar Profesor</h1>
    <p class="subtitulo">Registrar profesor para <b>@nombreMateria</b></p>

    @if (modeloProfesor != null)
    {
        <EditForm Model="modeloProfesor"
                  OnValidSubmit="GuardarProfesor"
                  FormName="formProfesor">

            <div class="form-group">
                <label>Nombre del profesor</label>
                <InputText class="form-input"
                           @bind-Value="modeloProfesor.Nombre"/>
            </div>

            <div class="form-group">
                <label>Opinión del estudiante</label>
                <InputTextArea class="form-input"
                               @bind-Value="modeloProfesor.Opinion"/>
            </div>

            <div class="form-group">
                <label>Puntaje</label>

                <div class="rating">

                    @for (int i = 1; i <= 5; i++)
                    {
                        int estrella = i;

                        <span class="estrella @(modeloProfesor.Puntaje >= estrella ? "activa" : "")"
                              @onclick="() => SeleccionarPuntaje(estrella)">
                            ⭐
                        </span>
                    }

                </div>

            </div>

            <button type="submit" class="btn-guardar">
                Guardar Profesor
            </button>

        </EditForm>
    }

</div>

@code {

    [Parameter]
    public string nombreMateria { get; set; }

    [SupplyParameterFromForm]
    public FormProfesor modeloProfesor { get; set; } = new();

    protected override void OnInitialized()
    {
        modeloProfesor ??= new();
    }

    void SeleccionarPuntaje(int valor)
    {
        modeloProfesor.Puntaje = valor;
        StateHasChanged();
    }

    void GuardarProfesor()
    {
        Materia materia = new Materia(nombreMateria, "", 0, 0);

        Profesor profesor = new Profesor(
            modeloProfesor.Nombre,
            materia,
            modeloProfesor.Opinion,
            modeloProfesor.Puntaje
        );

        Repo.AgregarProfesor(profesor);

        Nav.NavigateTo($"/profesores/{nombreMateria}");
    }

    public class FormProfesor
    {
        public string Nombre { get; set; } = "";
        public string Opinion { get; set; } = "";
        public int Puntaje { get; set; }
    }
}

<style>

