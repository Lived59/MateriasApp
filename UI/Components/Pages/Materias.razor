@page "/"
@using Domain.Entities
@using Domain.Enums
@using Repository
@using Services
@inject MateriaRepository repo
@inject MateriaService materiaService
@rendermode InteractiveServer

@if (semestres == null)
{
    <div class="spinner">Cargando...</div>
}
else
{
<div class="user-bar">
    <div class="user-card">
        <i class="fas fa-user-graduate"></i>
        <div>
            <span class="label">Estudiante</span>
            <span class="value">@usuarioActual.Nombre</span>
        </div>
    </div>
    <div class="user-card">
        <i class="fas fa-star"></i>
        <div>
            <span class="label">Créditos Totales</span>
            <span class="value">@usuarioActual.ObtenerCreditosTotales()</span>
        </div>
    </div>
</div>

<div class="contenedor-principal">

    <div class="malla-wrapper">
        <div class="malla-grid">
            @foreach (var semestre in semestres)
            {
            <div class="semestre-col">
                <h3 class="semestre-titulo">Semestre @semestre.Numero</h3>

                @foreach (var materia in semestre.Materias)
                {
                    var puedeCursar = materiaService.PuedeCursar(materia, usuarioActual);
                    var esHija = materiaSeleccionada != null && 
                                 materia.Previas.Any(p => p.MateriaPrevia.Nombre == materiaSeleccionada.Nombre);
    
                    var esPadre = materiaSeleccionada != null && 
                                  materiaSeleccionada.Previas.Any(p => p.MateriaPrevia.Nombre == materia.Nombre);
    
                    <div class="materia-card @materia.Estado.ToString().ToLower() 
                        @(materia == materiaSeleccionada ? "seleccionada" : "")
                        @(esHija ? "efecto-desbloqueo" : "") 
                        @(esPadre ? "efecto-requisito" : "")" @onclick="() => SeleccionarMateria(materia)">
        
                        <div class="materia-indicador">
                            @if (materia.Estado == EstadoMateria.AprobadaTotal)
                            {
                                <span title="Aprobada Total">✅</span> 
                            }
                            else if (materia.Estado == EstadoMateria.AprobadaParcial)
                            {
                                <span title="Aprobada Parcial">⏳</span>
                            }
                            else if (materia.Estado == EstadoMateria.Cursando)
                            {
                                <span title="Cursando">📘</span>
                            }
                            else if (puedeCursar)
                            {
                                <span title="Disponible">⭐</span>
                            }
                            else
                            {
                                <span title="Bloqueada">🔒</span>
                            }
                        </div>

                        <div class="materia-contenido">
                            <div class="materia-nombre">@materia.Nombre</div>
                            <div class="materia-detalles">Dif: @materia.Dificultad</div>
                        </div>
                    </div>
                }
            </div>
            }
        </div>
    </div>
    <div class="panel-detalle">
        @if (materiaSeleccionada != null)
        {
        <div class="detalle-content">
            <h3>@materiaSeleccionada.Nombre</h3>
            <p class="descripcion">@materiaSeleccionada.Descripcion</p>

            <div class="stats-grid">
                <div class="stat-item">
                    <span class="label">Necesita créditos</span>
                    <span class="value">@materiaSeleccionada.CreditosNecesarios</span>
                </div>
                <div class="stat-item">
                    <span class="label">Dificultad</span>
                    <span class="value">@materiaSeleccionada.Dificultad/10</span>
                </div>
            </div>
            @if (materiaSeleccionada.Previas.Any())
            {
            <div class="previas-section">
                <h4>Materias Previas:</h4>
                <ul>
                    @foreach (var p in materiaSeleccionada.Previas)
                    {
                    <li class="@(p.MateriaPrevia.Estado >= (p.TipoCredito == TipoCreditoPrevia.Total ? EstadoMateria.AprobadaTotal : EstadoMateria.AprobadaParcial) ? "cumplida" : "pendiente")">
                        @p.MateriaPrevia.Nombre (@p.TipoCredito)
                    </li>
                    }
                </ul>
            </div>
            }

            <div class="estado-selector">
                <label>Estado de @materiaSeleccionada.Nombre:</label>
                <select @key="materiaSeleccionada.Nombre"
                        class="form-control"
                        @onchange="OnEstadoChanged">
                    

                    @foreach (EstadoMateria est in Enum.GetValues(typeof(EstadoMateria)))
                    {
                        <option value="@est" selected="@(materiaSeleccionada.Estado == est)">
                            @est.ToString()
                        </option>
                    }
                </select>
            </div>
            
            <div class="ver-profesores">
                <NavLink class="btn-profesores"
                         href="@($"/profesores/{materiaSeleccionada.Nombre}")">
                    Ver Profesores
                </NavLink>
            </div>
        </div>
        }
        else
        {
        <div class="empty-state">
            <i class="fas fa-mouse-pointer"></i>
            <p>Selecciona una materia para ver requisitos y cambiar estado</p>
        </div>
        }
    </div>
</div>
}

@code {
    private List<Semestre> semestres;
    private Materia materiaSeleccionada;
    private Usuario usuarioActual;

    protected override void OnInitialized()
    {
        semestres = repo.ObtenerSemestres();
        usuarioActual = new Usuario("Francisco Menchaca");


        foreach (var s in semestres)
        {
            foreach (var m in s.Materias)
            {
                usuarioActual.Materias.Add(m);
            }
        }
    }

    private void SeleccionarMateria(Materia m) => materiaSeleccionada = m;

    private void OnEstadoChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<EstadoMateria>(e.Value?.ToString(), out var nuevoEstado))
        {
            if (nuevoEstado != EstadoMateria.NoCursada)
            {
                if (!materiaService.PuedeCursar(materiaSeleccionada, usuarioActual))
                {
                    StateHasChanged(); 
                    return;
                }
            }

            materiaSeleccionada.CambiarEstado(nuevoEstado);
            StateHasChanged();
        }
    }

}


<style>

:root{
    --bg-color:#f4f7f6;
    --card-bg:#ffffff;
    --border-color:#e0e6ed;

    --primary-blue:#007bff;
    --success-green:#28a745;
    --warning-yellow:#ffc107;

    --glass-bg:rgba(255,255,255,0.08);
}

/* =========================================
   FONDO GENERAL
   ========================================= */

body{
    margin:0;
    font-family:'Segoe UI',Tahoma,sans-serif;

    background:linear-gradient(
        135deg,
        #0f2027,
        #203a43,
        #2c5364
    );

    min-height:100vh;
}

/* luces decorativas */

body::before,
body::after{
    content:"";
    position:fixed;
    width:500px;
    height:500px;
    border-radius:50%;
    filter:blur(150px);
    opacity:0.35;
    z-index:-1;
}

body::before{
    background:#4facfe;
    top:-100px;
    left:-100px;
}

body::after{
    background:#00f2fe;
    bottom:-150px;
    right:-150px;
}

/* =========================================
   BARRA DE USUARIO
   ========================================= */

.user-bar{
    display:flex;
    gap:20px;
    margin-bottom:20px;
}

.user-card{
    background:linear-gradient(
        135deg,
        rgba(52,58,64,0.95),
        rgba(30,35,40,0.95)
    );

    backdrop-filter:blur(10px);

    box-shadow:0 5px 15px rgba(0,0,0,0.25);

    padding:12px 20px;
    border-radius:10px;
    display:flex;
    align-items:center;
    gap:15px;

    color:white;
}

.user-card i{
    font-size:1.5rem;
    color:var(--warning-yellow);
}

.user-card .label{
    display:block;
    font-size:0.75rem;
    opacity:0.8;
}

.user-card .value{
    font-weight:bold;
    font-size:1.1rem;
}

/* =========================================
   LAYOUT PRINCIPAL
   ========================================= */

.contenedor-principal{
    display:grid;
    grid-template-columns:1fr 380px;
    gap:20px;
    align-items:flex-start;
}

/* =========================================
   MALLA DE SEMESTRES
   ========================================= */

.malla-wrapper{
    background:var(--glass-bg);
    backdrop-filter:blur(15px);

    border-radius:20px;
    border:1px solid rgba(255,255,255,0.15);

    padding:20px;
    overflow-x:auto;
}

.malla-grid{
    display:flex;
    gap:15px;
}

.semestre-col{
    min-width:220px;

    display:flex;
    flex-direction:column;
    gap:12px;
}

.semestre-titulo{
    text-align:center;

    background:linear-gradient(
        135deg,
        #4facfe,
        #00f2fe
    );

    color:white;
    font-weight:bold;

    border-radius:10px;
    padding:8px;

    letter-spacing:0.5px;
}

/* =========================================
   TARJETAS DE MATERIAS
   ========================================= */

.materia-card{
    display:flex;
    align-items:center;
    gap:10px;

    background:rgba(255,255,255,0.95);

    border:none;
    border-radius:12px;

    padding:10px;
    min-height:65px;

    cursor:pointer;

    box-shadow:
        0 5px 12px rgba(0,0,0,0.08),
        inset 0 1px rgba(255,255,255,0.6);

    transition:all 0.25s ease;
}

.materia-card:hover{
    transform:translateY(-5px) scale(1.02);
    box-shadow:0 12px 25px rgba(0,0,0,0.15);
}

.materia-card.seleccionada{
    box-shadow:
        0 0 0 3px var(--primary-blue),
        0 10px 25px rgba(0,0,0,0.25);

    transform:scale(1.05);
}

/* estados */

.materia-card.aprobadatotal{
    background-color:#d4edda !important;
}

.materia-card.aprobadaparcial{
    background-color:#fff3cd !important;
}

.materia-card.cursando{
    background-color:#cce5ff !important;
    border-style:dashed;
}

/* contenido materia */

.materia-indicador{
    font-size:1.4rem;
    min-width:30px;
    display:flex;
    justify-content:center;
}

.materia-nombre{
    font-weight:600;
    font-size:0.85rem;
    line-height:1.1;
    color:#333;
}

.materia-detalles{
    font-size:0.7rem;
    color:#666;
    margin-top:4px;
}

/* =========================================
   PANEL DETALLE
   ========================================= */

.panel-detalle{
    background:rgba(255,255,255,0.9);
    backdrop-filter:blur(10px);

    border-radius:18px;
    border:1px solid var(--border-color);

    padding:25px;

    position:sticky;
    top:20px;

    box-shadow:0 10px 25px rgba(0,0,0,0.05);
}

.stats-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:15px;
    margin:20px 0;
}

.stat-item{
    background:#f8f9fa;
    padding:10px;
    border-radius:8px;
    text-align:center;
}

.stat-item .label{
    display:block;
    font-size:0.7rem;
    color:#6c757d;
}

.stat-item .value{
    font-weight:bold;
}

.previas-section ul{
    list-style:none;
    padding:0;
}

.previas-section li{
    font-size:0.85rem;
    padding:5px 0;
}

.previas-section li.cumplida{
    color:var(--success-green);
}

.previas-section li.pendiente{
    color:#dc3545;
}

.estado-selector{
    margin-top:25px;
    border-top:1px solid #eee;
    padding-top:15px;
}

.estado-selector label{
    font-size:0.9rem;
    font-weight:bold;
    margin-bottom:10px;
    display:block;
}

/* =========================================
   BOTONES
   ========================================= */

.ver-profesores{
    margin-top:20px;
}

.btn-profesores{
    background:linear-gradient(
        135deg,
        #4facfe,
        #00f2fe
    );

    padding:12px 26px;

    color:white;
    border-radius:10px;

    text-decoration:none;
    font-weight:bold;

    transition:0.3s;
}

.btn-profesores:hover{
    transform:translateY(-3px);
    box-shadow:0 6px 15px rgba(0,0,0,0.2);
}

/* =========================================
   EMPTY STATE
   ========================================= */

.empty-state{
    text-align:center;
    color:#adb5bd;
    padding:40px 0;
}

.empty-state i{
    font-size:3rem;
    margin-bottom:15px;
}

/* =========================================
   EFECTOS VISUALES
   ========================================= */

.efecto-desbloqueo{
    border:2px solid #00ff88 !important;
    box-shadow:0 0 10px #00ff88;
}

.efecto-requisito{
    border:2px dashed #ffcc00 !important;
    background-color:rgba(255,204,0,0.1);
}

</style>