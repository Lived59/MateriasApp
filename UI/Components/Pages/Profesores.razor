@page "/profesores/{nombreMateria}"
@using Domain.Entities
@using Repository
@inject ProfesorRepository Repo

<div class="pagina-profesores">

    <NavLink href="/" class="btn-volver">
        ← Volver
    </NavLink>

    <div class="header">
        <h1>Profesores de @nombreMateria</h1>

        <NavLink class="btn-agregar"
                 href="@($"/agregar-profesor/{nombreMateria}")">
            + Agregar Profesor
        </NavLink>
    </div>

    <h2 class="titulo-lista">Profesores registrados</h2>

    @if (profesores.Count == 0)
    {
        <p class="sin-profesores">No hay profesores registrados todavía.</p>
    }
    else
    {
        <div class="lista-profesores">

            @foreach (var profesor in profesores)
            {
                <div class="card-profesor">

                    <h3>@profesor.Nombre</h3>

                    <div class="puntaje">
                        Puntaje: ⭐ @profesor.Puntaje
                    </div>

                    <p class="opinion">
                        "@profesor.Opinion"
                    </p>

                </div>
            }

        </div>
    }

</div>

@code{

    [Parameter]
    public string nombreMateria { get; set; }

    List<Profesor> profesores = new();

    protected override void OnParametersSet()
    {
        profesores = Repo.ObtenerPorMateria(nombreMateria);
    }

}

<style>

/* ========================================
   CONTENEDOR GENERAL
======================================== */

.pagina-profesores{
max-width:1000px;
margin:auto;
padding:40px 20px;
color:#333;
}

/* ========================================
   BOTON VOLVER
======================================== */

.btn-volver{

display:inline-block;
margin-bottom:20px;

text-decoration:none;
font-weight:600;

color:#007bff;

transition:0.2s;

}

.btn-volver:hover{

transform:translateX(-4px);

}

/* ========================================
   HEADER
======================================== */

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:35px;

padding:20px 25px;
border-radius:14px;

background:linear-gradient(
135deg,
#4facfe,
#00f2fe
);

color:white;
box-shadow:0 8px 20px rgba(0,0,0,0.15);
}

.header h1{
font-size:30px;
margin:0;
letter-spacing:0.5px;
}

/* ========================================
   BOTON AGREGAR
======================================== */

.btn-agregar{
background:white;
color:#007bff;

padding:10px 18px;
border-radius:8px;

font-weight:600;
text-decoration:none;

transition:all 0.25s;
}

.btn-agregar:hover{
transform:translateY(-2px);
box-shadow:0 5px 15px rgba(0,0,0,0.2);
}

/* ========================================
   TITULO LISTA
======================================== */

.titulo-lista{
font-size:22px;
margin-bottom:20px;
color:#444;
}

/* ========================================
   GRID PROFESORES
======================================== */

.lista-profesores{
display:grid;
grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
gap:22px;
}

/* ========================================
   CARD PROFESOR
======================================== */

.card-profesor{

background:rgba(255,255,255,0.9);
backdrop-filter:blur(10px);

padding:22px;
border-radius:14px;

box-shadow:0 10px 25px rgba(0,0,0,0.08);

transition:all 0.25s;
position:relative;
}

.card-profesor:hover{
transform:translateY(-6px) scale(1.02);
box-shadow:0 15px 35px rgba(0,0,0,0.15);
}

.card-profesor h3{
margin:0 0 8px 0;
font-size:20px;
}

/* ========================================
   PUNTAJE
======================================== */

.puntaje{

font-weight:600;
margin:10px 0;

color:#f39c12;
font-size:16px;
}

/* ========================================
   OPINION
======================================== */

.opinion{

font-style:italic;
color:#555;

margin-top:10px;
line-height:1.4;
}

/* ========================================
   ESTADO VACIO
======================================== */

.sin-profesores{

text-align:center;
padding:40px;

background:rgba(255,255,255,0.7);
border-radius:12px;

color:#777;
font-size:16px;

}

</style>